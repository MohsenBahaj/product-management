# =============================================================================
# Product Management System — .gitignore
# =============================================================================

# ----- Node.js / Backend -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tsbuildinfo

# ----- Environment files -----
.env
.env.local
.env.*.local
!.env.example

# ----- Uploads (user content) -----
backend/uploads/products/*
backend/uploads/profiles/*
backend/uploads/categories/*
!backend/uploads/products/.gitkeep
!backend/uploads/profiles/.gitkeep
!backend/uploads/categories/.gitkeep

# ----- Docker -----
.docker/

# ----- Build outputs -----
dist/
build/
out/

# ----- Flutter (apps/mobile) -----
apps/mobile/.dart_tool/
apps/mobile/.flutter-plugins
apps/mobile/.flutter-plugins-dependencies
apps/mobile/.packages
apps/mobile/build/
apps/mobile/.idea/
apps/mobile/*.iml
apps/mobile/android/.gradle/
apps/mobile/android/local.properties
apps/mobile/android/app/debug.keystore
apps/mobile/ios/Pods/
apps/mobile/ios/.symlinks/
apps/mobile/ios/Flutter/Generated.xcconfig
apps/mobile/ios/Flutter/flutter_export_environment.sh

# ----- React / Vite (apps/web) -----
apps/web/node_modules/
apps/web/dist/
apps/web/.vite/

# ----- OS / Editor -----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ----- Testing -----
coverage/
.nyc_output/

# ----- Logs -----
logs/
*.log

# ----- Screenshots (populated manually) -----
# screenshots/*
!screenshots/.gitkeep
