# =============================================================================
# Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ----- Server -----
NODE_ENV=development
PORT=3001

# ----- Database -----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/product_management_db

# ----- Authentication -----
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ----- File Uploads -----
UPLOAD_MAX_SIZE_MB=5

# ----- Firebase Storage -----
# Required for all image uploads (product thumbnails, gallery, categories, profiles).
# See backend/README.md → Firebase Setup for step-by-step instructions.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# ----- CORS -----
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ----- Rate Limiting — Auth endpoints -----
# Stricter limit to prevent brute-force login attacks
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW=15

# ----- Rate Limiting — General API -----
# Broader limit to protect against accidental flooding
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW=15

# ----- Production (Railway) -----
# DATABASE_URL is auto-injected by the Railway PostgreSQL plugin
